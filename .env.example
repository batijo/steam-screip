DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_URLS=
DATABASE_PATH=data/db.json
SCRAPE_INTERVAL_SECONDS=300
LOG_LEVEL=INFO
DISCORD_USERNAME=Steam Free Games
DISCORD_AVATAR_URL=
DISCORD_MESSAGE_TEMPLATE=🎮 New Free Steam Game\n\n{name}\n{steam_url}
STEAMDB_SALES_URL=https://steamdb.info/sales/?sort=discount_desc
SCRAPE_USER_AGENT=Mozilla/5.0 (Macintosh; Intel Mac OS X 10.15; rv:150.0) Gecko/20100101 Firefox/150.0
SCRAPE_ACCEPT=text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8
SCRAPE_ACCEPT_LANGUAGE=en-US,en;q=0.9
SCRAPE_ACCEPT_ENCODING=gzip, deflate, br
SCRAPE_IMPERSONATE=firefox
SCRAPE_TIMEOUT_SECONDS=30
PARSER_TABLE_ROWS_XPATH=//table[contains(@class, 'table-sales')]//tbody/tr
PARSER_DISCOUNT_XPATH=.//td[contains(@class, 'price-discount') and @data-sort='100']
PARSER_NAME_XPATH=.//a[contains(@class, 'b') and contains(@href, '/app/')]
PARSER_STORE_XPATH=.//a[contains(@class, 'info-icon') and contains(@href, 'store.steampowered.com')]
RETENTION_DAYS=30
